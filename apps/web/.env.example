# 前端 WebSocket 连接地址（指向 BFF）
VITE_BFF_WS_URL=ws://localhost:3000

# 运行环境: development | preview | production
VITE_APP_ENV=development

# 前端成本控制策略（与 packages/config schema 保持一致）
VITE_FRAME_MAX_WIDTH=512
VITE_FRAME_QUALITY=0.7
VITE_ENABLE_CHANGE_DETECTION=true
VITE_ENABLE_VISION_FALLBACK=true
VITE_MAX_HISTORY_ROUNDS=10
VITE_WS_NAMESPACE=video
