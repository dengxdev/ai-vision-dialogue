# BFF 服务端口
BFF_PORT=3000

# WebSocket 命名空间（前后端需保持一致，前面不要加 /）
WS_NAMESPACE=video

# CORS 允许的源（生产环境请改为实际前端域名）
BFF_CORS_ORIGIN=http://localhost:5173

# 视觉模型 API 配置（通义千问 VL）
VISION_API_KEY=your_vision_api_key_here
VISION_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
VISION_MODEL=qwen-vl-plus

# LLM API 配置（通义千问 Turbo）
LLM_API_KEY=your_llm_api_key_here
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_MODEL=qwen-turbo

# 端侧图像压缩与成本控制（与 packages/config/src/schema.ts 保持一致）
FRAME_MAX_WIDTH=512
FRAME_QUALITY=0.7
ENABLE_CHANGE_DETECTION=true
ENABLE_VISION_FALLBACK=true
MAX_HISTORY_ROUNDS=10

# BFF 限流
ENABLE_RATE_LIMIT=true
RPM_LIMIT=60

# 运行环境（development / preview / production）
APP_ENV=development

# 是否 mock 数据
ENABLE_MOCK_VISION=false
ENABLE_MOCK_LLM=false
